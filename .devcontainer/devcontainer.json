{
  "name": "util-box",
  // renovate: datasource=docker
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu24.04@sha256:7ee7da33a68d997971660d91ecc8372e55a38a777c3c6bd6808daf91928052db",
  "features": {
    "ghcr.io/devcontainers-extra/features/mise:1": {
      // renovate: datasource=github-releases depName=jdx/mise
      "version": "v2026.4.7"
    }
  },
  "customizations": {
    "vscode": {
      "settings": {
        "yaml.format.bracketSpacing": false,
        "yaml.format.printWidth": 160
      },
      "extensions": [
        "1Password.op-vscode",
        "aaron-bond.better-comments",
        "EditorConfig.EditorConfig",
        "hverlin.mise-vscode",
        "mrmlnc.vscode-json5",
        "ms-python.python",
        "oderwat.indent-rainbow",
        "redhat.ansible",
        "samuelcolvin.jinjahtml",
        "savh.json5-kit",
        "tamasfe.even-better-toml",
        "vivaxy.vscode-conventional-commits"
      ]
    }
  },
  "mounts": [
    "source=mise-data-volume,target=/mnt/mise-data,type=volume",
    "source=util-box-bashhistory,target=/commandhistory,type=volume",
    "source=${localEnv:HOME}/.ssh/config,target=/ssh_config,type=bind"
  ],
  "containerEnv": {
    "MISE_DATA_DIR": "/mnt/mise-data"
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/mnt/mise-data/shims"
  },
  "postCreateCommand": [
    "bash",
    ".devcontainer/postCreate.sh"
  ],
  //"initializeCommand": "op inject -fi .devcontainer/devcontainer.env.tmpl -o .devcontainer/devcontainer.env",
  "runArgs": [
    "--env-file",
    ".devcontainer/devcontainer.env"
  ]
}
