{
  "name": "util-box",
  // renovate: datasource=docker
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu24.04@sha256:4bcb1b466771b1ba1ea110e2a27daea2f6093f9527fb75ee59703ec89b5561cb",
  "features": {
    "ghcr.io/devcontainers-extra/features/mise:1": {
      // renovate: datasource=github-releases depName=jdx/mise
      "version": "v2026.4.7"
    }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "1Password.op-vscode",
        "aaron-bond.better-comments",
        "EditorConfig.EditorConfig",
        "hverlin.mise-vscode",
        "mrmlnc.vscode-json5",
        "ms-python.python",
        "oderwat.indent-rainbow",
        "redhat.ansible",
        "samuelcolvin.jinjahtml",
        "savh.json5-kit",
        "tamasfe.even-better-toml",
        "vivaxy.vscode-conventional-commits"
      ]
    }
  },
  "mounts": [
    {
      "source": "mise-data-volume",
      "target": "/mnt/mise-data",
      "type": "volume"
    },
    {
      "source": "util-box-bashhistory",
      "target": "/commandhistory",
      "type": "volume"
    },
    {
      "source": "${localEnv:HOME}/.ssh/config",
      "target": "/ssh_config",
      "type": "bind"
    }
  ],
  "containerEnv": {
    "MISE_DATA_DIR": "/mnt/mise-data"
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/mnt/mise-data/shims"
  },
  "postCreateCommand": [
    "bash",
    ".devcontainer/postCreate.sh"
  ],
  //"initializeCommand": "op inject -fi .devcontainer/devcontainer.env.tmpl -o .devcontainer/devcontainer.env",
  "runArgs": [
    "--env-file",
    ".devcontainer/devcontainer.env"
  ]
}
